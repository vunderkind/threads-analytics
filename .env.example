# Copy to .env and fill in the blanks.

# Threads app credentials — from developers.facebook.com → your app → Threads product
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://localhost/

# Populated automatically by `python scripts/setup_token.py` after OAuth
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_HANDLE=

# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides
DATABASE_URL=sqlite:///data/threads.db
CLAUDE_RECOMMENDER_MODEL=claude-opus-4-5
CLAUDE_TOPIC_MODEL=claude-sonnet-4-5
KEYWORD_SEARCH_BUDGET_PER_RUN=30
KEYWORD_SEARCH_ROLLING_BUDGET=400
